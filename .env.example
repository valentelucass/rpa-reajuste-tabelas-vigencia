# URL de login do sistema
URL_LOGIN=https://rodogarcia.eslcloud.com.br/users/sign_in

# Credenciais de acesso
EMAIL_LOGIN=seu_email@empresa.com.br
SENHA_LOGIN=sua_senha

# Comportamento do navegador
HEADLESS=false
DEBUG_VISUAL=false

# Confirmacao final antes de salvar (false = modo seguro)
CONFIRMAR_FINAL=true

# Timeouts em segundos
TIMEOUT=30
PAGE_LOAD_TIMEOUT=60
TIMEOUT_COPIA_FINALIZADA=600
INTERVALO_LOG_PROGRESSO_POPUP=30

# Limites de retencao de artefatos
MAX_SCREENSHOTS_ARMAZENADOS=100
MAX_REGISTROS_PROCESSAMENTO=500
MAX_REGISTROS_TRACE=200
MAX_BYTES_LOG_ERROS=5242880
MAX_BACKUPS_LOG_ERROS=3
